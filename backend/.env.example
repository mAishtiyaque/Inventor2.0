# Example environment variables for Inventor.Api
# Copy to .env and fill values before running locally

# Database connection: either a connection string named DefaultConnection in appsettings or DATABASE_URL
# Example Postgres URL: postgres://username:password@host:5432/dbname
DATABASE_URL=

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development

# Optional: override URLs
# ASPNETCORE_URLS=http://localhost:5048;https://localhost:7175

# Any other secrets the app expects (fill as needed)
# SECRET_KEY=
